<h1>新規登録</h1>

<%= form_with model: @user, url: signup_path, local: true do |f| %>
  <div>
    <%= f.label :name %>
    <%= f.text_field :name %>
  </div>

  <div>
    <%= f.label :email %>
    <%= f.email_field :email %>
  </div>

  <div>
    <%= f.label :password %>
    <%= f.password_field :password %>
  </div>

  <div>
    <%= f.label :password_confirmation %>
    <%= f.password_field :password_confirmation %>
  </div>

  <div>
    <%= f.label :profile %>
    <%= f.text_area :profile %>
  </div>

  <div>
    <%= f.submit "登録する" %>
  </div>
<% end %>